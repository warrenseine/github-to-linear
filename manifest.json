{
  "manifest_version": 3,
  "name": "GitHub PR → Linear Review",
  "version": "0.1.0",
  "description": "Adds a 'View in Linear' tab to GitHub pull requests: self-assigns you as reviewer and opens the PR review in Linear.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["github.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://linear.app/*"],
      "js": ["linear.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
