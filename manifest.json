{
  "manifest_version": 3,
  "name": "GitHub PR → Linear Review",
  "version": "0.1.0",
  "description": "Adds a 'View in Linear' tab to GitHub pull requests that opens the matching Linear review.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["github.js"],
      "run_at": "document_idle"
    }
  ]
}
