{
  "name": "github-to-linear",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension: adds a 'View in Linear' tab to GitHub PRs that opens the matching Linear review.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
